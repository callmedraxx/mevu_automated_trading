# PostgreSQL
POSTGRES_USER=mevu_system
POSTGRES_PASSWORD=your-password
POSTGRES_DB=automated_trading

# Database URL (inside Docker - containers use internal ports)
DATABASE_URL=postgres://mevu_system:your-password@postgres:5432/automated_trading

# Redis (inside Docker)
REDIS_URL=redis://redis:6379

# Server
PORT=4500
RUST_LOG=info

# Privy (same app as /root/mevu)
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# MEVU API - for proxy wallet deployment via Polymarket relayer (with rotating keys)
# Required for auto-deploying proxy wallet on first bot register.
# Docker: use host.docker.internal when mevu runs in separate compose on same host
# Shared network: use http://app:3000 (mevu service name)
MEVU_API_URL=http://host.docker.internal:3000
# Optional: set only if mevu has MEVU_INTERNAL_API_KEY configured
# MEVU_INTERNAL_API_KEY=
